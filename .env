# Deploy config (committed — this is config, NOT secrets). See PLAN.md / starter README.
#
# !!! TODO before first push (push to main = LIVE deploy):
#     replace the placeholder below with your real domain, with an A-record
#     pointed at the platform server IP.
DOMAIN=gpugrid.app

# docker-db: the Dockerfile builds web + runs the Bun gateway (serves site + API),
# with a persistent SQLite volume at /data (DATABASE_URL injected automatically).
DEPLOY=docker-db
APP_PORT=8080

# Secrets to inject into the container at runtime. Set their values in
# the deploy platform → repo → Settings → Actions → Secrets (names must match).
# RUNPOD_API_KEY enables the cloud GPU fallback; ADMIN_KEY enables /api/admin/*;
# GGRID_AUTHORITY_KEY enables on-chain $GGRID payouts (the program authority keypair).
RUNTIME_KEYS=RUNPOD_API_KEY,ADMIN_KEY,GGRID_AUTHORITY_KEY

# --- $GGRID on-chain payouts (optional) ---
# Leave blank to keep payouts OFF. Fill after `anchor deploy` + `initialize`.
# (Config, not secrets — the authority KEYPAIR goes in the deploy platform Secrets above.)
SOLANA_RPC_URL=
GGRID_PROGRAM_ID=
GGRID_MINT=
GGRID_TOKEN_PROGRAM=token2022
# How many raw $GGRID units equal 1 credit (1 micro-USD). Set from token price.
GGRID_RAW_PER_CREDIT=1
GGRID_PROVIDER_BPS=7500
GGRID_MIN_PAYOUT_CREDITS=100000
